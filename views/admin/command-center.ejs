<%- include('../partials/header') %>

<%
  const money = value => `$${Math.round(Number(value || 0)).toLocaleString()}`;
  const percent = value => `${Math.round(Number(value || 0) * 100)}%`;
  const number = value => Math.round(Number(value || 0)).toLocaleString();
  const funnelRows = Array.isArray(typeof leadFunnel !== 'undefined' ? leadFunnel : null) ? leadFunnel : [];
  const profit = typeof soldProfit !== 'undefined' && soldProfit ? soldProfit : {};
  const profitRows = Array.isArray(profit.profitRows) ? profit.profitRows : [];
  const profitStart = profit.trackingStart ? new Date(profit.trackingStart).toLocaleDateString() : 'today';
  const isCommandSold = car => Boolean(car && (car.sold || car.commandCenterSold));
%>

<section class="container admin-shell admin-page command-center-page">
  <div class="admin-hero">
    <div>
      <span class="admin-kicker">Inventory Command Center</span>
      <h1>Dealer Dashboard</h1>
      <p>Track capital, buyer activity, pricing pressure, and this week's inventory actions.</p>
    </div>

    <div class="admin-hero-actions">
      <a href="/admin/dashboard" class="btn btn-secondary">Inventory</a>
      <a href="/admin/command-center/weekly" class="btn btn-secondary">Weekly Actions</a>
      <a href="/admin/command-center/buying-scorecard" class="btn btn-secondary">Buying Scorecard</a>
      <a href="/admin/command-center/cargurus-import" class="btn btn-primary">CarGurus Import</a>
    </div>
  </div>

  <div class="command-kpi-grid" aria-label="Command center KPIs">
    <div class="admin-stat"><span>Total Vehicles</span><strong><%= number(kpis.totalVehicles) %></strong></div>
    <div class="admin-stat"><span>Capital Tied Up</span><strong><%= money(kpis.capitalTiedUp) %></strong></div>
    <div class="admin-stat"><span>Total Asking Value</span><strong><%= money(kpis.totalAskingValue) %></strong></div>
    <div class="admin-stat"><span>Potential Gross</span><strong><%= money(kpis.potentialGross) %></strong></div>
    <div class="admin-stat"><span>Average ROI</span><strong><%= percent(kpis.averageRoi) %></strong></div>
    <div class="admin-stat"><span>Avg Days In Stock</span><strong><%= number(kpis.averageDaysInStock) %></strong></div>
    <div class="admin-stat"><span>Aging 30 / 45 / 60</span><strong><%= kpis.over30 %> / <%= kpis.over45 %> / <%= kpis.over60 %></strong></div>
    <div class="admin-stat"><span>Leads This Month</span><strong><%= number(kpis.leadsThisMonth) %></strong></div>
    <div class="admin-stat"><span>Appointments This Month</span><strong><%= number(kpis.appointmentsThisMonth) %></strong></div>
    <div class="admin-stat"><span>Sales This Month</span><strong><%= number(kpis.salesThisMonth) %></strong></div>
    <div class="admin-stat"><span>Lead-to-Sale</span><strong><%= percent(kpis.leadToSaleConversion) %></strong></div>
  </div>

  <div class="admin-panel command-filter-panel">
    <form method="GET" action="/admin/command-center" class="command-filters">
      <label>
        <span>Status</span>
        <select name="status">
          <option value="active" <%= filters.status === 'active' ? 'selected' : '' %>>Active inventory</option>
          <option value="sold" <%= filters.status === 'sold' ? 'selected' : '' %>>Sold inventory</option>
          <option value="all" <%= filters.status === 'all' ? 'selected' : '' %>>All vehicles</option>
        </select>
      </label>

      <label>
        <span>Sort</span>
        <select name="sort">
          <option value="days" <%= filters.sort === 'days' ? 'selected' : '' %>>Days in stock</option>
          <option value="gross" <%= filters.sort === 'gross' ? 'selected' : '' %>>Potential gross</option>
          <option value="roi" <%= filters.sort === 'roi' ? 'selected' : '' %>>ROI</option>
          <option value="capital" <%= filters.sort === 'capital' ? 'selected' : '' %>>Capital invested</option>
          <option value="leads" <%= filters.sort === 'leads' ? 'selected' : '' %>>Leads</option>
        </select>
      </label>

      <label>
        <span>Search</span>
        <input type="text" name="search" value="<%= filters.search %>" placeholder="VIN, stock, model" />
      </label>

      <button type="submit" class="btn btn-primary">Apply</button>
    </form>
  </div>

  <div class="admin-panel command-profit-panel">
    <div class="admin-panel-header">
      <div>
        <h2>Sold Profit Tracker</h2>
        <p>Recorded gross from cars sold on or after <%= profitStart %> with final sale price and cost details filled in.</p>
      </div>
    </div>

    <div class="command-profit-grid" aria-label="Sold profit summary">
      <div class="admin-stat"><span>Total Profit</span><strong><%= money(profit.totalProfit) %></strong></div>
      <div class="admin-stat"><span>This Month</span><strong><%= money(profit.profitThisMonth) %></strong></div>
      <div class="admin-stat"><span>Sold Units</span><strong><%= number(profit.soldUnits) %></strong></div>
      <div class="admin-stat"><span>Off-site Cars</span><strong><%= money(profit.offsiteCarProfit) %></strong></div>
      <div class="admin-stat"><span>Tire Profit</span><strong><%= money(profit.tireProfit) %></strong></div>
      <div class="admin-stat"><span>Sold ROI</span><strong><%= percent(profit.averageRoi) %></strong></div>
    </div>

    <div class="command-profit-entry-grid">
      <div class="command-profit-entry">
        <h3>Off-site car</h3>
        <form class="command-extra-profit-form" action="/admin/command-center/offsite-car-profit" method="POST">
          <label>
            <span>Car</span>
            <input type="text" name="vehicleLabel" placeholder="Example: Civic beater" />
          </label>
          <label>
            <span>Bought for</span>
            <input type="number" name="purchaseCost" min="0" step="1" placeholder="Bought for" />
          </label>
          <label>
            <span>Sold for</span>
            <input type="number" name="salePrice" min="0" step="1" placeholder="Sold for" required />
          </label>
          <label>
            <span>Date</span>
            <input type="date" name="date" />
          </label>
          <label>
            <span>Note</span>
            <input type="text" name="note" placeholder="Cousin / off-site sale" />
          </label>
          <button type="submit" class="btn btn-primary">Add Off-site Car</button>
        </form>
      </div>

      <div class="command-profit-entry">
        <h3>Tires</h3>
        <form class="command-tire-form" action="/admin/command-center/tire-profit" method="POST">
          <label>
            <span>Profit</span>
            <input type="number" name="amount" min="0" step="1" placeholder="Amount made" required />
          </label>
          <label>
            <span>Date</span>
            <input type="date" name="date" />
          </label>
          <label>
            <span>Note</span>
            <input type="text" name="note" placeholder="Example: winter tires" />
          </label>
          <button type="submit" class="btn btn-primary">Add Tires</button>
        </form>
      </div>
    </div>

    <% if (profitRows.length > 0) { %>
      <div class="admin-table-wrap command-profit-table-wrap">
        <table class="admin-table command-table command-profit-table">
          <thead>
            <tr>
              <th>Sold Item</th>
              <th>Bought For</th>
              <th>Sold For</th>
              <th>Profit</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% profitRows.forEach(item => { %>
              <tr>
                <td data-label="Sold Item">
                  <strong><%= item.label || 'Sold item' %></strong>
                  <% if (item.date) { %>
                    <span class="admin-cell-meta"><%= new Date(item.date).toLocaleDateString() %></span>
                  <% } %>
                  <% if (item.note && item.type !== 'Tires') { %>
                    <span class="admin-cell-meta"><%= item.note %></span>
                  <% } %>
                  <% if (item.car) { %>
                    <a class="admin-cell-meta command-row-link" href="/admin/cars/<%= item.car._id %>/edit">Edit sale details</a>
                  <% } %>
                </td>
                <td data-label="Bought For">
                  <% if (item.car) { %>
                    <strong><%= money(item.boughtFor) %></strong>
                    <details class="command-inline-editor">
                      <summary>Edit</summary>
                      <form class="command-price-form command-quick-form" action="/admin/command-center/cars/<%= item.car._id %>/investment" method="POST">
                        <label>
                          <span>Bought for</span>
                          <input type="number" name="purchaseCost" min="0" step="1" value="<%= item.car.purchaseCost || '' %>" placeholder="Bought for" />
                        </label>
                        <button type="submit" class="btn btn-secondary command-table-button">Update</button>
                      </form>
                    </details>
                  <% } else if (item.boughtFor !== null && typeof item.boughtFor !== 'undefined') { %>
                    <strong><%= money(item.boughtFor) %></strong>
                  <% } else { %>
                    <span class="admin-muted">-</span>
                  <% } %>
                </td>
                <td data-label="Sold For">
                  <% if (item.car) { %>
                    <strong><%= money(item.soldFor) %></strong>
                    <details class="command-inline-editor">
                      <summary>Edit</summary>
                      <form class="command-price-form command-quick-form" action="/admin/command-center/cars/<%= item.car._id %>/pricing" method="POST">
                        <label>
                          <span>Sold for</span>
                          <input type="number" name="finalSalePrice" min="0" step="1" value="<%= item.car.finalSalePrice || '' %>" placeholder="Sold for" />
                        </label>
                        <button type="submit" class="btn btn-secondary command-table-button">Update</button>
                      </form>
                    </details>
                  <% } else { %>
                    <strong><%= money(item.soldFor) %></strong>
                  <% } %>
                </td>
                <td data-label="Profit" class="<%= item.profit < 0 ? 'command-negative' : '' %>"><strong><%= money(item.profit) %></strong></td>
                <td data-label="Status">
                  <span class="status-badge <%= item.type === 'Tires' ? 'status-available' : 'status-sold' %>"><%= item.type %></span>
                  <% if (item.car && item.car.commandCenterSold && !item.car.sold) { %>
                    <form action="/admin/command-center/cars/<%= item.car._id %>/toggle-sold" method="POST">
                      <button type="submit" class="btn btn-muted command-table-button">Put Back Unsold</button>
                    </form>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <p class="admin-muted">No sold items yet. Add a car sale, off-site car, or tire profit to start tracking.</p>
    <% } %>
  </div>

  <div class="admin-panel">
    <div class="admin-panel-header">
      <div>
        <h2>Profit Workbench</h2>
        <p>Quick private view of what you bought it for, what you sold it for, profit, and ROI.</p>
      </div>
    </div>

    <% if (rows.length > 0) { %>
      <div class="admin-table-wrap command-table-wrap">
        <table class="admin-table command-table">
          <thead>
            <tr>
              <th>Vehicle</th>
              <th>Bought For</th>
              <th>Sold / Asking</th>
              <th>Profit</th>
              <th>ROI</th>
              <th>Command Sale</th>
            </tr>
          </thead>
          <tbody>
            <% rows.forEach(({ car, metrics }) => { %>
              <tr>
                <td data-label="Vehicle">
                  <div class="admin-vehicle-cell">
                    <% if (car.images && car.images.length > 0) { %>
                      <img src="<%= car.images[0] %>" alt="<%= metrics.label %>" />
                    <% } else { %>
                      <div class="admin-table-placeholder">No image</div>
                    <% } %>
                    <div>
                      <strong><%= metrics.label || 'Vehicle' %></strong>
                      <span><%= car.stockNumber ? `Stock ${car.stockNumber}` : (car.vin || 'No VIN') %></span>
                    </div>
                  </div>
                </td>
                <td data-label="Bought For">
                  <strong><%= money(metrics.totalInvested) %></strong>
                  <form class="command-price-form command-quick-form" action="/admin/command-center/cars/<%= car._id %>/investment" method="POST">
                    <label>
                      <span>Bought for</span>
                      <input type="number" name="purchaseCost" min="0" step="1" value="<%= car.purchaseCost || '' %>" placeholder="Bought for" />
                    </label>
                    <button type="submit" class="btn btn-secondary command-table-button">Save</button>
                  </form>
                </td>
                <td data-label="Sold / Asking">
                  <strong><%= isCommandSold(car) ? money(car.finalSalePrice || metrics.privateAskingPrice) : money(metrics.privateAskingPrice) %></strong>
                  <form class="command-price-form command-quick-form" action="/admin/command-center/cars/<%= car._id %>/pricing" method="POST">
                    <% if (isCommandSold(car)) { %>
                      <label>
                        <span>Sold for</span>
                        <input type="number" name="finalSalePrice" min="0" step="1" value="<%= car.finalSalePrice || '' %>" placeholder="Sold for" />
                      </label>
                    <% } else { %>
                      <label>
                        <span>Private ask</span>
                        <input type="number" name="commandCenterPrice" min="0" step="1" value="<%= car.commandCenterPrice || '' %>" placeholder="<%= car.price ? Math.round(car.price) : 'Private ask' %>" />
                      </label>
                    <% } %>
                    <button type="submit" class="btn btn-secondary command-table-button">Save</button>
                  </form>
                  <% if (car.price) { %>
                    <span class="admin-cell-meta">Website: <%= money(car.price) %></span>
                  <% } else { %>
                    <span class="admin-cell-meta">No website price</span>
                  <% } %>
                </td>
                <td data-label="Profit" class="<%= (isCommandSold(car) ? metrics.soldGross : metrics.potentialGross) < 0 ? 'command-negative' : '' %>"><strong><%= money(isCommandSold(car) ? metrics.soldGross : metrics.potentialGross) %></strong></td>
                <td data-label="ROI"><%= percent(isCommandSold(car) ? metrics.soldRoi : metrics.roi) %></td>
                <td data-label="Command Sale">
                  <% if (car.sold) { %>
                    <span class="status-badge status-sold">Public Sold</span>
                  <% } else if (car.commandCenterSold) { %>
                    <span class="status-badge status-sold">Command Sold</span>
                  <% } else { %>
                    <form action="/admin/command-center/cars/<%= car._id %>/toggle-sold" method="POST">
                      <button type="submit" class="btn btn-info command-table-button">Mark Sold</button>
                    </form>
                  <% } %>

                  <% if (car.commandCenterSold && !car.sold) { %>
                    <form action="/admin/command-center/cars/<%= car._id %>/toggle-sold" method="POST">
                      <button type="submit" class="btn btn-muted command-table-button">Put Back Unsold</button>
                    </form>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="admin-empty">
        <h2>No vehicles match this view</h2>
        <p>Change filters or add inventory financial details from the vehicle editor.</p>
      </div>
    <% } %>
  </div>

  <div class="admin-panel">
    <div class="admin-panel-header">
      <div>
        <h2>Lead Funnel</h2>
        <p>Recent buyer activity by vehicle, source, and stage.</p>
      </div>
    </div>

    <% if (funnelRows.length > 0) { %>
      <div class="admin-table-wrap">
        <table class="admin-table command-table command-funnel-table">
          <thead>
            <tr>
              <th>Vehicle</th>
              <th>Source</th>
              <th>Stage</th>
              <th>Customer</th>
              <th>Date</th>
              <th>Notes</th>
            </tr>
          </thead>
          <tbody>
            <% funnelRows.slice(0, 20).forEach(lead => { %>
              <tr>
                <td data-label="Vehicle"><strong><%= lead.vehicle %></strong></td>
                <td data-label="Source"><%= lead.source %></td>
                <td data-label="Stage"><span class="status-badge command-action-badge"><%= lead.stage %></span></td>
                <td data-label="Customer"><%= lead.customerName || '-' %></td>
                <td data-label="Date"><%= lead.date ? new Date(lead.date).toLocaleDateString() : '-' %></td>
                <td data-label="Notes"><%= lead.notes || '-' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="admin-empty">
        <h2>No leads logged yet</h2>
        <p>Add leads inside a vehicle editor to track source, stage, appointments, show-ups, and sales.</p>
      </div>
    <% } %>
  </div>
</section>

<%- include('../partials/footer') %>
