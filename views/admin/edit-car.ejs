<%- include('../partials/header') %>

<section class="form-card">
  <h1 class="form-title">Edit Car</h1>

  <% if (error) { %>
    <div style="color:#ffb3c7;margin-bottom:10px;"><strong><%= error %></strong></div>
  <% } %>

  <form id="editCarForm" action="/admin/cars/<%= car._id %>/edit" method="POST" class="form" enctype="multipart/form-data">
    <div class="form-row">
      <div>
        <label class="label">Make</label>
        <input type="text" value="<%= car.make %>" readonly disabled />
      </div>
      <div>
        <label class="label">Model</label>
        <input type="text" value="<%= car.model %>" readonly disabled />
      </div>
    </div>

    <div class="form-row">
      <div>
        <label class="label">Year</label>
        <input type="number" value="<%= car.year %>" readonly disabled />
      </div>
      <div>
        <label class="label">Price (editable)</label>
        <input type="number" name="price" value="<%= car.price %>" required min="0" step="1" />
      </div>
    </div>

    <div class="form-row">
      <div>
        <label class="label">Exterior Color</label>
        <select name="exteriorColor">
          <option value="">Select exterior</option>
          <% ['Black','White','Gray','Silver','Blue','Red','Green','Brown','Beige','Yellow','Orange','Purple','Gold','Other'].forEach(c => { %>
            <option value="<%= c %>" <%= car.exteriorColor === c ? 'selected' : '' %>><%= c %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label class="label">Interior Color</label>
        <select name="interiorColor">
          <option value="">Select interior</option>
          <% ['Black','Gray','Beige / Tan','Brown','Red','White','Blue','Other'].forEach(c => { %>
            <option value="<%= c %>" <%= car.interiorColor === c ? 'selected' : '' %>><%= c %></option>
          <% }) %>
        </select>
      </div>
    </div>

    <div class="form-row">
      <div>
        <label class="label">Mileage (km)</label>
        <input type="number" name="mileage" value="<%= typeof car.mileage === 'number' ? car.mileage : '' %>" />
      </div>
      <div>
        <label class="label">Engine</label>
        <input type="text" name="engine" value="<%= car.engine || '' %>" />
      </div>
    </div>

    <div class="form-row">
      <div>
        <label class="label">Transmission</label>
        <select name="transmission">
          <option value="">Select transmission</option>
          <% ['Automatic','Manual','Dual clutch','CVT','Other'].forEach(t => { %>
            <option value="<%= t %>" <%= car.transmission === t ? 'selected' : '' %>><%= t %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label class="label">Drivetrain</label>
        <select name="drivetrain">
          <option value="">Select drivetrain</option>
          <% ['AWD','FWD','RWD','4WD / 4x4'].forEach(d => { %>
            <option value="<%= d %>" <%= car.drivetrain === d ? 'selected' : '' %>><%= d %></option>
          <% }) %>
        </select>
      </div>
    </div>

    <div class="form-row">
      <div>
        <label class="label">Fuel</label>
        <select name="fuel">
          <option value="">Select fuel</option>
          <% ['Gasoline','Diesel','Hybrid','Plug in Hybrid','Electric','Flex Fuel','Other'].forEach(f => { %>
            <option value="<%= f %>" <%= car.fuel === f ? 'selected' : '' %>><%= f %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label class="label">Body Style</label>
        <select name="bodyStyle">
          <option value="">Select body style</option>
          <% ['Sedan','Hatchback','Coupe','Convertible','SUV','Crossover','Truck','Van / Minivan','Wagon','Other'].forEach(b => { %>
            <option value="<%= b %>" <%= car.bodyStyle === b ? 'selected' : '' %>><%= b %></option>
          <% }) %>
        </select>
      </div>
    </div>

    <div>
      <label class="label">VIN</label>
      <input type="text" name="vin" value="<%= car.vin || '' %>" />
    </div>

    <div>
      <label class="label">Short Description</label>
      <textarea name="description" rows="5"><%= car.description || '' %></textarea>
    </div>

    <div class="stack-m">
      <strong>All Images (drag to reorder)</strong>
      <ul id="dndList" class="dnd-list" aria-label="Reorder images"></ul>
      <input type="hidden" id="imagesOrderInput" name="imagesOrder" value="" />
      <input type="hidden" id="deletedImagesInput" name="deletedImages" value="" />
      <small style="color:var(--muted);">Tip: the first image is the main photo on the site.</small>
    </div>

    <div class="stack-m">
      <label class="label" for="newImages">Attach more photos</label>
      <input id="newImages" type="file" name="newImages" accept="image/*" multiple />
      <small style="color:var(--muted);display:block;margin-top:6px;">
        You can add up to 30 total uploads. New photos appear right away.
      </small>
    </div>

    <div class="row">
      <button type="submit" class="btn btn-primary">Save Changes</button>
      <a href="/admin/dashboard" class="btn btn-muted">← Back to Dashboard</a>
    </div>
  </form>
</section>

<style>
  .dnd-list{
    list-style:none;
    margin:0;
    padding:0;
    display:grid;
    grid-template-columns:repeat(auto-fill, minmax(220px, 1fr));
    gap:14px;
  }

  .dnd-item{
    position:relative;
    background:#0c1018;
    border:1px solid rgba(255,255,255,.12);
    border-radius:12px;
    overflow:hidden;
    padding:0;
    cursor:grab;
  }

  .dnd-item.dragging{
    opacity:.55;
    border-color:var(--brand);
  }

  .dnd-item img{
    display:block;
    width:100%;
    height:180px;
    object-fit:cover;
  }

  .dnd-handle{
    position:absolute;
    top:8px;
    left:8px;
    background:rgba(0,0,0,.65);
    border:1px solid rgba(255,255,255,.18);
    color:#fff;
    border-radius:8px;
    padding:4px 7px;
    font-weight:700;
    cursor:grab;
    user-select:none;
    z-index:3;
  }

  .img-del{
    position:absolute;
    top:8px;
    right:8px;
    width:30px;
    height:30px;
    border:none;
    border-radius:999px;
    background:rgba(190,24,93,.95);
    color:#fff;
    font-size:16px;
    font-weight:700;
    cursor:pointer;
    z-index:3;
    display:flex;
    align-items:center;
    justify-content:center;
  }

  .img-del:hover{
    transform:scale(1.06);
  }

  .dnd-label{
    position:absolute;
    bottom:8px;
    right:8px;
    font-size:12px;
    font-weight:800;
    background:rgba(0,0,0,.65);
    border:1px solid rgba(255,255,255,.18);
    color:#fff;
    padding:3px 7px;
    border-radius:999px;
    z-index:3;
  }

  .img-kind{
    position:absolute;
    bottom:8px;
    left:8px;
    font-size:11px;
    font-weight:700;
    padding:3px 7px;
    border-radius:999px;
    background:rgba(0,0,0,.65);
    border:1px solid rgba(255,255,255,.18);
    color:#fff;
    z-index:3;
  }
</style>

<script id="existingImagesData" type="application/json">
  <%- JSON.stringify(car.images || []) %>
</script>

<script id="existingImagesData" type="application/json">
  <%- JSON.stringify(car.images || []) %>
</script>

<script>
(function () {
  const form = document.getElementById('editCarForm');
  const list = document.getElementById('dndList');
  const newInput = document.getElementById('newImages');
  const imagesOrderInput = document.getElementById('imagesOrderInput');
  const deletedImagesInput = document.getElementById('deletedImagesInput');

  const existingImages = JSON.parse(
    document.getElementById('existingImagesData').textContent || '[]'
  );

  let items = existingImages.map(img => ({
    id: img,
    src: img,
    type: 'existing'
  }));

  let deletedExistingImages = [];
  let newFiles = [];
  let dragId = null;

  function syncHiddenInputs() {
    imagesOrderInput.value = items.map(item => item.id).join(',');
    deletedImagesInput.value = deletedExistingImages.join(',');
  }

  function render() {
    list.innerHTML = '';

    items.forEach((item, index) => {
      const li = document.createElement('li');
      li.className = 'dnd-item';
      li.draggable = true;
      li.dataset.id = item.id;

      const img = document.createElement('img');
      img.src = item.src;
      img.alt = `car image ${index + 1}`;

      const handle = document.createElement('div');
      handle.className = 'dnd-handle';
      handle.textContent = '⋮⋮';

      const removeBtn = document.createElement('button');
      removeBtn.type = 'button';
      removeBtn.className = 'img-del';
      removeBtn.textContent = '✕';
      removeBtn.title = 'Delete photo';

      removeBtn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();

        if (item.type === 'existing') {
          if (!deletedExistingImages.includes(item.src)) {
            deletedExistingImages.push(item.src);
          }
        } else {
          const fileIndex = newFiles.findIndex(f => f.tempId === item.id);
          if (fileIndex !== -1) {
            URL.revokeObjectURL(items.find(x => x.id === item.id)?.src || '');
            newFiles.splice(fileIndex, 1);
          }
        }

        items = items.filter(x => x.id !== item.id);
        render();
      });

      const label = document.createElement('span');
      label.className = 'dnd-label';
      label.textContent = String(index + 1);

      const kind = document.createElement('span');
      kind.className = 'img-kind';
      kind.textContent = item.type === 'existing' ? 'saved' : 'new';

      li.addEventListener('dragstart', () => {
        dragId = item.id;
        li.classList.add('dragging');
      });

      li.addEventListener('dragend', () => {
        dragId = null;
        li.classList.remove('dragging');
      });

      li.addEventListener('dragover', (e) => {
        e.preventDefault();
      });

      li.addEventListener('drop', (e) => {
        e.preventDefault();
        if (!dragId || dragId === item.id) return;

        const fromIndex = items.findIndex(x => x.id === dragId);
        const toIndex = items.findIndex(x => x.id === item.id);
        if (fromIndex === -1 || toIndex === -1) return;

        const moved = items.splice(fromIndex, 1)[0];
        items.splice(toIndex, 0, moved);

        render();
      });

      li.appendChild(img);
      li.appendChild(handle);
      li.appendChild(removeBtn);
      li.appendChild(label);
      li.appendChild(kind);

      list.appendChild(li);
    });

    syncHiddenInputs();
  }

  function fileToImage(file) {
    return new Promise((resolve, reject) => {
      const url = URL.createObjectURL(file);
      const img = new Image();
      img.onload = () => {
        URL.revokeObjectURL(url);
        resolve(img);
      };
      img.onerror = reject;
      img.src = url;
    });
  }

  async function compressImage(file, maxWidth = 1400, quality = 0.8) {
    const img = await fileToImage(file);
    const canvas = document.createElement('canvas');
    const scale = Math.min(1, maxWidth / img.width);

    canvas.width = Math.round(img.width * scale);
    canvas.height = Math.round(img.height * scale);

    const ctx = canvas.getContext('2d');
    ctx.drawImage(img, 0, 0, canvas.width, canvas.height);

    let blob = await new Promise(res => canvas.toBlob(res, 'image/webp', quality));
    if (!blob) {
      blob = await new Promise(res => canvas.toBlob(res, 'image/jpeg', 0.85));
    }

    const ext = blob.type.includes('webp') ? 'webp' : 'jpg';

    return new File(
      [blob],
      `${file.name.replace(/\.[^.]+$/, '')}.${ext}`,
      {
        type: blob.type,
        lastModified: Date.now()
      }
    );
  }

  newInput.addEventListener('change', () => {
    const incoming = Array.from(newInput.files || []);

    for (const file of incoming) {
      const tempId = `new_${Date.now()}_${Math.random().toString(36).slice(2, 8)}`;
      const previewUrl = URL.createObjectURL(file);

      newFiles.push({ tempId, file });
      items.push({
        id: tempId,
        src: previewUrl,
        type: 'new'
      });
    }

    render();
    newInput.value = '';
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const submitBtn = form.querySelector('button[type="submit"]');
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = 'Saving...';
    }

    try {
      syncHiddenInputs();

      const fd = new FormData();
      new FormData(form).forEach((v, k) => {
        if (k !== 'newImages') fd.append(k, v);
      });

      for (const item of newFiles) {
        const compressed = await compressImage(item.file, 1400, 0.8);
        fd.append('newImages', compressed, compressed.name);
      }

      const resp = await fetch(form.action, {
        method: 'POST',
        body: fd
      });

      if (resp.redirected) {
        window.location.href = resp.url;
      } else if (resp.ok) {
        window.location.reload();
      } else {
        alert('Save failed: ' + await resp.text());
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Save Changes';
        }
      }
    } catch (err) {
      console.error(err);
      alert('Save failed. See console for details.');
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Save Changes';
      }
    }
  });

  render();
})();
</script>

<%- include('../partials/footer') %>