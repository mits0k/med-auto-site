<%- include('../partials/header') %>

<section class="form-card admin-car-editor">
  <div class="admin-form-header">
    <span class="admin-form-eyebrow">Inventory Manager</span>
    <h1 class="form-title">Edit <%= car.make %> <%= car.model %></h1>
    <p>Update the listing details and arrange the vehicle photos.</p>
  </div>

  <% if (error) { %>
    <div style="color:#ffb3c7;margin-bottom:10px;"><strong><%= error %></strong></div>
  <% } %>

  <form id="editCarForm" action="/admin/cars/<%= car._id %>/edit" method="POST" class="form" enctype="multipart/form-data">
    <section class="admin-form-section" aria-labelledby="edit-basics-title">
      <div class="admin-form-section-title">
        <span>1</span>
        <div><h2 id="edit-basics-title">Vehicle basics</h2><p>The information customers see first.</p></div>
      </div>
    <div class="form-row">
  <div>
    <label class="label">Make</label>
    <input
      type="text"
      name="make"
      value="<%= car.make %>"
      required
    />
  </div>

  <div>
    <label class="label">Model</label>
    <input
      type="text"
      name="model"
      value="<%= car.model %>"
      required
    />
  </div>
</div>

    <div class="form-row">
      <div>
        <label class="label">Year</label>
        <input type="number" value="<%= car.year %>" readonly disabled />
      </div>
      <div>
        <label class="label">Price (editable)</label>
        <input
  type="number"
  name="price"
  value="<%= car.price || '' %>"
  min="0"
  step="1"
/>
        <small class="form-helper">If this changes, a private price-history entry will be logged.</small>
      </div>
    </div>

    <div class="form-row">
      <div>
        <label class="label">Trim</label>
        <input type="text" name="trim" value="<%= car.trim || '' %>" />
      </div>
      <div>
        <label class="label">Stock #</label>
        <input type="text" name="stockNumber" value="<%= car.stockNumber || '' %>" />
      </div>
    </div>

    <div>
      <label class="label">Price Change Reason</label>
      <input type="text" name="priceChangeReason" placeholder="Optional note if changing asking price" />
    </div>
    </section>

    <section class="admin-form-section" aria-labelledby="edit-specs-title">
      <div class="admin-form-section-title">
        <span>2</span>
        <div><h2 id="edit-specs-title">Specifications</h2><p>Color, mileage, and mechanical details.</p></div>
      </div>
    <div class="form-row">
      <div>
        <label class="label">Exterior Color</label>
        <select name="exteriorColor">
          <option value="">Select exterior</option>
          <% ['Black','White','Gray','Silver','Blue','Red','Green','Brown','Beige','Yellow','Orange','Purple','Gold','Other'].forEach(c => { %>
            <option value="<%= c %>" <%= car.exteriorColor === c ? 'selected' : '' %>><%= c %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label class="label">Interior Color</label>
        <select name="interiorColor">
          <option value="">Select interior</option>
          <% ['Black','Gray','Beige / Tan','Brown','Red','White','Blue','Other'].forEach(c => { %>
            <option value="<%= c %>" <%= car.interiorColor === c ? 'selected' : '' %>><%= c %></option>
          <% }) %>
        </select>
      </div>
    </div>

    <div class="form-row">
      <div>
        <label class="label">Mileage (km)</label>
        <input type="number" name="mileage" value="<%= typeof car.mileage === 'number' ? car.mileage : '' %>" />
      </div>
      <div>
        <label class="label">Engine</label>
        <input type="text" name="engine" value="<%= car.engine || '' %>" />
      </div>
    </div>

    <div class="form-row">
      <div>
        <label class="label">Transmission</label>
        <select name="transmission">
          <option value="">Select transmission</option>
          <% ['Automatic','Manual','Dual clutch','CVT','Other'].forEach(t => { %>
            <option value="<%= t %>" <%= car.transmission === t ? 'selected' : '' %>><%= t %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label class="label">Drivetrain</label>
        <select name="drivetrain">
          <option value="">Select drivetrain</option>
          <% ['AWD','FWD','RWD','4WD / 4x4'].forEach(d => { %>
            <option value="<%= d %>" <%= car.drivetrain === d ? 'selected' : '' %>><%= d %></option>
          <% }) %>
        </select>
      </div>
    </div>

    <div class="form-row">
      <div>
        <label class="label">Fuel</label>
        <select name="fuel">
          <option value="">Select fuel</option>
          <% ['Gasoline','Diesel','Hybrid','Plug in Hybrid','Electric','Flex Fuel','Other'].forEach(f => { %>
            <option value="<%= f %>" <%= car.fuel === f ? 'selected' : '' %>><%= f %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label class="label">Body Style</label>
        <select name="bodyStyle">
          <option value="">Select body style</option>
          <% ['Sedan','Hatchback','Coupe','Convertible','SUV','Crossover','Truck','Van / Minivan','Wagon','Other'].forEach(b => { %>
            <option value="<%= b %>" <%= car.bodyStyle === b ? 'selected' : '' %>><%= b %></option>
          <% }) %>
        </select>
      </div>
    </div>
    </section>

    <section class="admin-form-section" aria-labelledby="edit-listing-title">
      <div class="admin-form-section-title">
        <span>3</span>
        <div><h2 id="edit-listing-title">Listing details</h2><p>Review the VIN and customer-facing description.</p></div>
      </div>
    <div>
      <label class="label">VIN</label>
      <input type="text" name="vin" value="<%= car.vin || '' %>" />
    </div>

    <div>
      <label class="label">Short Description</label>
      <textarea name="description" rows="5"><%= car.description || '' %></textarea>
    </div>
    </section>

    <section class="admin-form-section command-financial-section" aria-labelledby="edit-financial-title">
      <div class="admin-form-section-title">
        <span>4</span>
        <div>
          <h2 id="edit-financial-title">Private Financials</h2>
          <p>Admin-only profitability, cost, status, and sale tracking.</p>
        </div>
      </div>

      <div class="command-summary-strip">
        <div><span>Total invested</span><strong>$<%= Math.round(metrics.totalInvested || 0).toLocaleString() %></strong></div>
        <div><span>Potential gross</span><strong>$<%= Math.round(metrics.potentialGross || 0).toLocaleString() %></strong></div>
        <div><span>ROI</span><strong><%= Math.round((metrics.roi || 0) * 100) %>%</strong></div>
        <div><span>Recommendation</span><strong><%= metrics.recommendation.action %></strong></div>
      </div>

      <div class="form-row">
        <div>
          <label class="label">Purchase Cost</label>
          <input type="number" name="purchaseCost" value="<%= car.purchaseCost || '' %>" min="0" step="1" />
        </div>
        <div>
          <label class="label">Purchase Date</label>
          <input type="date" name="purchaseDate" value="<%= car.purchaseDate ? car.purchaseDate.toISOString().slice(0, 10) : '' %>" />
        </div>
      </div>

      <div class="form-row">
        <div>
          <label class="label">Auction / Source</label>
          <input type="text" name="auctionSource" value="<%= car.auctionSource || '' %>" placeholder="Auction, trade, private, referral" />
        </div>
        <div>
          <label class="label">Admin Vehicle Status</label>
          <select name="adminStatus">
            <% ['Retail Ready','In Recon','Needs Photos','Needs Detail','On Hold','Active Buyer','Sold','Wholesale Review'].forEach(status => { %>
              <option value="<%= status %>" <%= car.adminStatus === status ? 'selected' : '' %>><%= status %></option>
            <% }) %>
          </select>
        </div>
      </div>

      <div class="form-row">
        <div>
          <label class="label">Auction Fees</label>
          <input type="number" name="auctionFees" value="<%= car.auctionFees || '' %>" min="0" step="1" />
        </div>
        <div>
          <label class="label">Transport</label>
          <input type="number" name="transportCost" value="<%= car.transportCost || '' %>" min="0" step="1" />
        </div>
      </div>

      <div class="form-row">
        <div>
          <label class="label">Inspection</label>
          <input type="number" name="inspectionCost" value="<%= car.inspectionCost || '' %>" min="0" step="1" />
        </div>
        <div>
          <label class="label">Active Buyer Status</label>
          <input type="text" name="activeBuyerStatus" value="<%= car.activeBuyerStatus || '' %>" placeholder="Active lead, appointment booked, buyer paused" />
        </div>
      </div>

      <div class="command-subsection">
        <div class="admin-panel-header command-inline-header">
          <div>
            <h2>Recon / Repair Expenses</h2>
            <p>Add every repair line that changes total invested.</p>
          </div>
          <button type="button" class="btn btn-secondary" data-add-row="recon">Add Recon Row</button>
        </div>

        <div id="reconRows" class="command-row-editor">
          <% const reconRows = (car.reconExpenses && car.reconExpenses.length ? car.reconExpenses : [{}]); %>
          <% reconRows.forEach(expense => { %>
            <div class="command-edit-row">
              <input type="date" name="reconDate" value="<%= expense.date ? expense.date.toISOString().slice(0, 10) : '' %>" />
              <select name="reconCategory">
                <% ['Mechanical','Body','Detail','Tires','Brakes','Glass','Inspection','Other'].forEach(category => { %>
                  <option value="<%= category %>" <%= expense.category === category ? 'selected' : '' %>><%= category %></option>
                <% }) %>
              </select>
              <input type="text" name="reconDescription" value="<%= expense.description || '' %>" placeholder="Description" />
              <input type="number" name="reconAmount" value="<%= expense.amount || '' %>" min="0" step="1" placeholder="Amount" />
              <button type="button" class="btn btn-muted command-remove-row">Remove</button>
            </div>
          <% }) %>
        </div>
      </div>

      <div class="form-row">
        <div>
          <label class="label">Sale Date</label>
          <input type="date" name="saleDate" value="<%= car.saleDate ? car.saleDate.toISOString().slice(0, 10) : '' %>" />
        </div>
        <div>
          <label class="label">Final Sale Price</label>
          <input type="number" name="finalSalePrice" value="<%= car.finalSalePrice || '' %>" min="0" step="1" />
        </div>
      </div>

      <div class="form-row">
        <div>
          <label class="label">Recommendation Override</label>
          <input type="text" name="recommendationOverride" value="<%= car.recommendationOverride || '' %>" placeholder="Example: HOLD + CONVERT INTEREST" />
        </div>
        <div>
          <label class="label">Recommendation Note</label>
          <textarea name="recommendationNote" rows="2" placeholder="Why this manual action is active"><%= car.recommendationNote || '' %></textarea>
        </div>
      </div>

      <div>
        <label class="label">Private Notes</label>
        <textarea name="privateNotes" rows="4"><%= car.privateNotes || '' %></textarea>
      </div>
    </section>

    <section class="admin-form-section command-financial-section" aria-labelledby="edit-market-title">
      <div class="admin-form-section-title">
        <span>5</span>
        <div>
          <h2 id="edit-market-title">Lead Funnel & Market Signals</h2>
          <p>Track sources, stages, CarGurus saves, IMV, and deal rating.</p>
        </div>
      </div>

      <div class="form-row">
        <div>
          <label class="label">CarGurus Saves</label>
          <input type="number" name="cargurusSaves" value="<%= car.cargurus?.saves || '' %>" min="0" step="1" />
        </div>
        <div>
          <label class="label">CarGurus IMV</label>
          <input type="number" name="cargurusImv" value="<%= car.cargurus?.imv || '' %>" min="0" step="1" />
        </div>
      </div>

      <div class="form-row">
        <div>
          <label class="label">Deal Rating</label>
          <input type="text" name="cargurusDealRating" value="<%= car.cargurus?.dealRating || '' %>" placeholder="Great Deal, Good Deal, Fair Deal" />
        </div>
        <div>
          <label class="label">Days on CarGurus</label>
          <input type="number" name="cargurusDaysOnMarket" value="<%= car.cargurus?.daysOnMarket || '' %>" min="0" step="1" />
        </div>
      </div>

      <div class="command-subsection">
        <div class="admin-panel-header command-inline-header">
          <div>
            <h2>Leads</h2>
            <p>Log platform, stage, and next-step notes by vehicle.</p>
          </div>
          <button type="button" class="btn btn-secondary" data-add-row="lead">Add Lead Row</button>
        </div>

        <div id="leadRows" class="command-row-editor">
          <% const leadRows = (car.leads && car.leads.length ? car.leads : [{}]); %>
          <% leadRows.forEach(lead => { %>
            <div class="command-edit-row command-lead-row">
              <input type="date" name="leadDate" value="<%= lead.date ? lead.date.toISOString().slice(0, 10) : '' %>" />
              <select name="leadSource">
                <option value="">Source</option>
                <% LEAD_SOURCES.forEach(source => { %>
                  <option value="<%= source %>" <%= lead.source === source ? 'selected' : '' %>><%= source %></option>
                <% }) %>
              </select>
              <select name="leadStage">
                <option value="">Stage</option>
                <% LEAD_STAGES.forEach(stage => { %>
                  <option value="<%= stage %>" <%= lead.stage === stage ? 'selected' : '' %>><%= stage %></option>
                <% }) %>
              </select>
              <input type="text" name="leadCustomerName" value="<%= lead.customerName || '' %>" placeholder="Customer" />
              <input type="text" name="leadContact" value="<%= lead.contact || '' %>" placeholder="Phone/email" />
              <input type="text" name="leadNotes" value="<%= lead.notes || '' %>" placeholder="Notes" />
              <button type="button" class="btn btn-muted command-remove-row">Remove</button>
            </div>
          <% }) %>
        </div>
      </div>

      <div class="command-subsection">
        <div class="admin-panel-header command-inline-header">
          <div>
            <h2>Price History</h2>
            <p>Every asking-price change is tracked automatically when this form is saved.</p>
          </div>
        </div>

        <% if (car.priceHistory && car.priceHistory.length > 0) { %>
          <div class="price-timeline">
            <% car.priceHistory.slice().reverse().forEach(item => { %>
              <article class="price-timeline-item">
                <strong>$<%= Math.round(item.oldPrice || 0).toLocaleString() %> to $<%= Math.round(item.newPrice || 0).toLocaleString() %></strong>
                <span><%= item.date ? item.date.toLocaleDateString() : 'No date' %> · <%= item.reason || 'Price update' %></span>
                <p><%= item.savesBeforeChange || 0 %> saves · <%= item.leadsBeforeChange || 0 %> leads · <%= item.appointmentsBeforeChange || 0 %> appointments before change</p>
              </article>
            <% }) %>
          </div>
        <% } else { %>
          <p class="admin-muted">No price changes logged yet.</p>
        <% } %>
      </div>
    </section>

    <section class="admin-form-section admin-photo-section" aria-labelledby="edit-photos-title">
      <div class="admin-form-section-title">
        <span>6</span>
        <div><h2 id="edit-photos-title">Photos</h2><p>Reorder existing photos or attach new ones.</p></div>
      </div>
    <div class="stack-m">
      <strong>Existing images <span class="admin-inline-note">Drag to reorder</span></strong>

      <% if (car.images && car.images.length > 0) { %>
        <ul id="dndList" class="dnd-list" aria-label="Reorder images">
          <% car.images.forEach((img, i) => { %>
            <li class="dnd-item" draggable="true" data-src="<%= img %>">
              <div class="dnd-handle" title="Drag to reorder">⋮⋮</div>

              <button
                type="button"
                class="img-del"
                data-img="<%= img %>"
                title="Delete photo"
                aria-label="Delete photo"
              >✕</button>

              <img src="<%= img %>" alt="car image <%= i + 1 %>" />
              <span class="dnd-label"><%= i + 1 %></span>
            </li>
          <% }) %>
        </ul>
      <% } else { %>
        <ul id="dndList" class="dnd-list" aria-label="Reorder images"></ul>
        <p>No images</p>
      <% } %>

      <input type="hidden" id="imagesOrderInput" name="imagesOrder" value="" />
      <input type="hidden" id="deletedImagesInput" name="deletedImages" value="" />
      <small style="color:var(--muted);">Tip: the first image is the main photo on the site.</small>
    </div>

    <div class="stack-m admin-file-upload">
      <label class="label" for="newImages">Attach more photos</label>
      <input id="newImages" type="file" name="newImages" accept="image/*" multiple />
      <small style="color:var(--muted);display:block;margin-top:6px;">
        New photos will appear below right away.
      </small>
      <ul id="newPreviewList" class="dnd-list" aria-label="New image previews"></ul>
    </div>
    </section>

    <div class="row admin-form-actions">
      <button type="submit" class="btn btn-primary">Save Changes</button>
      <a href="/admin/dashboard" class="btn btn-muted">← Back to Dashboard</a>
    </div>
  </form>
</section>

<script>
  (function () {
    const list = document.getElementById('dndList');
    const newPreviewList = document.getElementById('newPreviewList');
    const input = document.getElementById('imagesOrderInput');
    const deletedImagesInput = document.getElementById('deletedImagesInput');
    const form = document.getElementById('editCarForm');
    const newInput = document.getElementById('newImages');

    let dragEl = null;
    let deletedExistingImages = [];
    let selectedNewFiles = [];

    const getItems = () => Array.from(list.querySelectorAll('.dnd-item'));
    const serialize = () =>
      getItems()
        .filter(li => li.dataset.src && !li.dataset.deleted)
        .map(li => li.dataset.src)
        .join(',');

    function updateLabels() {
      getItems()
        .filter(li => !li.dataset.deleted)
        .forEach((li, idx) => {
          const label = li.querySelector('.dnd-label');
          if (label) label.textContent = String(idx + 1);
        });
    }

    function syncDeletedImages() {
      deletedImagesInput.value = deletedExistingImages.join(',');
    }

    function syncOrder() {
      input.value = serialize();
    }

    function onDragStart(e) {
      const target = e.target.closest('.dnd-item');
      if (!target || target.dataset.deleted) return;
      dragEl = target;
      target.classList.add('dragging');
      e.dataTransfer.effectAllowed = 'move';
      e.dataTransfer.setData('text/plain', target.dataset.src);
    }

    function onDragOver(e) {
      e.preventDefault();
      const over = e.target.closest('.dnd-item');
      if (!over || over === dragEl || over.dataset.deleted) return;

      const rect = over.getBoundingClientRect();
      const before = (e.clientY - rect.top) < rect.height / 2;

      getItems().forEach(li => li.classList.remove('drop-target'));
      over.classList.add('drop-target');

      if (before) list.insertBefore(dragEl, over);
      else list.insertBefore(dragEl, over.nextSibling);
    }

    function onDragLeave(e) {
      const li = e.target.closest('.dnd-item');
      if (li) li.classList.remove('drop-target');
    }

    function onDrop(e) {
      e.preventDefault();
      getItems().forEach(li => li.classList.remove('drop-target'));
    }

    function onDragEnd() {
      if (dragEl) dragEl.classList.remove('dragging');
      dragEl = null;
      updateLabels();
      syncOrder();
    }

    if (list) {
      list.addEventListener('dragstart', onDragStart);
      list.addEventListener('dragover', onDragOver);
      list.addEventListener('dragleave', onDragLeave);
      list.addEventListener('drop', onDrop);
      list.addEventListener('dragend', onDragEnd);

      list.addEventListener('click', (e) => {
        const btn = e.target.closest('.img-del');
        if (!btn) return;

        const li = btn.closest('.dnd-item');
        const img = btn.dataset.img;
        if (!li || !img) return;

        if (!deletedExistingImages.includes(img)) {
          deletedExistingImages.push(img);
        }

        li.dataset.deleted = 'true';
        li.style.display = 'none';

        updateLabels();
        syncDeletedImages();
        syncOrder();
      });
    }

    function renderNewPreviews() {
      newPreviewList.innerHTML = '';

      selectedNewFiles.forEach((file, index) => {
        const li = document.createElement('li');
        li.className = 'dnd-item';

        const img = document.createElement('img');
        img.src = URL.createObjectURL(file);
        img.alt = `new image ${index + 1}`;

        const removeBtn = document.createElement('button');
        removeBtn.type = 'button';
        removeBtn.className = 'img-del';
        removeBtn.textContent = '✕';
        removeBtn.title = 'Remove new photo';

        removeBtn.addEventListener('click', () => {
          selectedNewFiles.splice(index, 1);
          renderNewPreviews();
        });

        const label = document.createElement('span');
        label.className = 'dnd-label';
        label.textContent = String(index + 1);

        const badge = document.createElement('span');
        badge.className = 'img-kind';
        badge.textContent = 'new';

        li.appendChild(removeBtn);
        li.appendChild(img);
        li.appendChild(label);
        li.appendChild(badge);
        newPreviewList.appendChild(li);
      });
    }

    function fileToImage(file) {
      return new Promise((resolve, reject) => {
        const url = URL.createObjectURL(file);
        const img = new Image();
        img.onload = () => {
          URL.revokeObjectURL(url);
          resolve(img);
        };
        img.onerror = reject;
        img.src = url;
      });
    }

    async function compressImage(file, maxWidth = 1400, quality = 0.8) {
      const img = await fileToImage(file);
      const canvas = document.createElement('canvas');
      const s = Math.min(1, maxWidth / img.width);

      canvas.width = Math.round(img.width * s);
      canvas.height = Math.round(img.height * s);

      const ctx = canvas.getContext('2d');
      ctx.drawImage(img, 0, 0, canvas.width, canvas.height);

      let blob = await new Promise(res => canvas.toBlob(res, 'image/webp', quality));
      if (!blob) blob = await new Promise(res => canvas.toBlob(res, 'image/jpeg', 0.85));

      const ext = blob.type.includes('webp') ? 'webp' : 'jpg';

      return new File([blob], `${file.name.replace(/\.[^.]+$/, '')}.${ext}`, {
        type: blob.type,
        lastModified: Date.now()
      });
    }

    newInput.addEventListener('change', () => {
      const incoming = Array.from(newInput.files || []);
      selectedNewFiles.push(...incoming);
      renderNewPreviews();
      newInput.value = '';
    });

    const reconRows = document.getElementById('reconRows');
    const leadRows = document.getElementById('leadRows');
    const reconCategories = ['Mechanical','Body','Detail','Tires','Brakes','Glass','Inspection','Other'];
    const leadSources = <%- JSON.stringify(LEAD_SOURCES) %>;
    const leadStages = <%- JSON.stringify(LEAD_STAGES) %>;

    function optionHtml(items, placeholder) {
      return `${placeholder ? `<option value="">${placeholder}</option>` : ''}${items.map(item => `<option value="${item}">${item}</option>`).join('')}`;
    }

    function addReconRow() {
      const row = document.createElement('div');
      row.className = 'command-edit-row';
      row.innerHTML = `
        <input type="date" name="reconDate" />
        <select name="reconCategory">${optionHtml(reconCategories)}</select>
        <input type="text" name="reconDescription" placeholder="Description" />
        <input type="number" name="reconAmount" min="0" step="1" placeholder="Amount" />
        <button type="button" class="btn btn-muted command-remove-row">Remove</button>
      `;
      reconRows.appendChild(row);
    }

    function addLeadRow() {
      const row = document.createElement('div');
      row.className = 'command-edit-row command-lead-row';
      row.innerHTML = `
        <input type="date" name="leadDate" />
        <select name="leadSource">${optionHtml(leadSources, 'Source')}</select>
        <select name="leadStage">${optionHtml(leadStages, 'Stage')}</select>
        <input type="text" name="leadCustomerName" placeholder="Customer" />
        <input type="text" name="leadContact" placeholder="Phone/email" />
        <input type="text" name="leadNotes" placeholder="Notes" />
        <button type="button" class="btn btn-muted command-remove-row">Remove</button>
      `;
      leadRows.appendChild(row);
    }

    document.addEventListener('click', (e) => {
      const addButton = e.target.closest('[data-add-row]');
      if (addButton) {
        if (addButton.dataset.addRow === 'recon') addReconRow();
        if (addButton.dataset.addRow === 'lead') addLeadRow();
      }

      const removeButton = e.target.closest('.command-remove-row');
      if (removeButton) {
        const row = removeButton.closest('.command-edit-row');
        const container = row ? row.parentElement : null;
        if (row && container && container.querySelectorAll('.command-edit-row').length > 1) {
          row.remove();
        } else if (row) {
          row.querySelectorAll('input').forEach(input => { input.value = ''; });
          row.querySelectorAll('select').forEach(select => { select.selectedIndex = 0; });
        }
      }
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      syncOrder();
      syncDeletedImages();

      const submitBtn = form.querySelector('button[type="submit"]');
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = 'Saving...';
      }

      try {
        const fd = new FormData();
        new FormData(form).forEach((v, k) => {
          if (k !== 'newImages') fd.append(k, v);
        });

        for (const file of selectedNewFiles) {
          const compressed = await compressImage(file, 1400, 0.8);
          fd.append('newImages', compressed, compressed.name);
        }

        const resp = await fetch(form.action, {
          method: 'POST',
          body: fd
        });

        if (resp.redirected) {
          window.location.href = resp.url;
        } else if (resp.ok) {
          window.location.reload();
        } else {
          alert('Save failed: ' + await resp.text());
          if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.textContent = 'Save Changes';
          }
        }
      } catch (err) {
        console.error(err);
        alert('Save failed. See console for details.');
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Save Changes';
        }
      }
    });

    updateLabels();
    syncOrder();
    syncDeletedImages();
  })();
</script>

