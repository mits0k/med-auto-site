<%- include('../partials/header') %>

<section class="container stack-l admin-page">
  <h1>Trade-In Requests</h1>

  <% if (tradeIns.length > 0) { %>

    <table>
      <thead>
        <tr>
          <th>Customer</th>
          <th>Vehicle</th>
          <th>Details</th>
          <th>Status</th>
          <th>Photos</th>
          <th>Message</th>
          <th style="width:220px;">Actions</th>
        </tr>
      </thead>

      <tbody>

        <% tradeIns.forEach(t => { %>

          <tr>

            <td>
              <strong><%= t.name %></strong>

              <div>
                <%= t.email || 'No email' %>
              </div>

              <div>
                <%= t.phone %>
              </div>
            </td>

            <td>
              <strong>
                <%= t.year %> <%= t.make %> <%= t.model %>
              </strong>

              <div>

                <% if (typeof t.mileage === 'number') { %>

                  <%= t.mileage.toLocaleString() %> km

                <% } else { %>

                  —

                <% } %>

              </div>

              <div>
                VIN: <%= t.vin || '—' %>
              </div>
            </td>

            <td>

              <div>
                Condition:
                <%= t.condition || '—' %>
              </div>

              <div>
                Asking:

                <% if (typeof t.askingPrice === 'number') { %>

                  $<%= t.askingPrice.toLocaleString() %>

                <% } else { %>

                  —

                <% } %>

              </div>

              <div>
                Sent:

                <% if (t.createdAt) { %>

                  <%= t.createdAt.toLocaleString() %>

                <% } else { %>

                  —

                <% } %>

              </div>

            </td>

            <td>

              <span class="status-badge <%= t.status === 'Closed'
                ? 'status-sold'
                : t.status === 'Contacted'
                ? 'status-contacted'
                : 'status-new' %>">

                <%= t.status || 'New' %>

              </span>

            </td>

            <td>

              <% if (t.images && t.images.length > 0) { %>

                <div class="trade-photo-grid">

                  <% t.images.forEach(img => { %>

                    <a href="<%= img %>" target="_blank">

                      <img
                        src="<%= img %>"
                        alt="Trade-in photo"
                      />

                    </a>

                  <% }) %>

                </div>

              <% } else { %>

                —

              <% } %>

            </td>

            <td style="max-width:280px; white-space:normal;">

              <%= t.message || '-' %>

            </td>

            <td>

              <div class="row">

                <form
                  action="/admin/trade-ins/<%= t._id %>/status"
                  method="POST"
                >

                  <select
                    name="status"
                    onchange="this.form.submit()"
                  >

                    <option
                      value="New"
                      <%= t.status === 'New' ? 'selected' : '' %>
                    >
                      New
                    </option>

                    <option
                      value="Contacted"
                      <%= t.status === 'Contacted' ? 'selected' : '' %>
                    >
                      Contacted
                    </option>

                    <option
                      value="Closed"
                      <%= t.status === 'Closed' ? 'selected' : '' %>
                    >
                      Closed
                    </option>

                  </select>

                </form>

                <form
                  action="/admin/trade-ins/<%= t._id %>/delete"
                  method="POST"
                  onsubmit="return confirm('Delete this trade-in request?');"
                >

                  <button
                    type="submit"
                    class="btn btn-danger"
                  >
                    Delete
                  </button>

                </form>

              </div>

            </td>

          </tr>

        <% }) %>

      </tbody>
    </table>

  <% } else { %>

    <p>No trade-in requests found.</p>

  <% } %>

  <div class="row">
    <a
      href="/admin/dashboard"
      class="btn btn-muted"
    >
      ← Back to Dashboard
    </a>
  </div>

</section>

<%- include('../partials/footer') %>
