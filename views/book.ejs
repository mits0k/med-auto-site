<%- include('partials/header') %>

<section class="booking-page">
  <header class="form-page-heading">
    <span class="section-eyebrow"><%= t('Plan your visit') %></span>
    <h1><%= t('Book an appointment') %></h1>
    <p><%= t('Choose a vehicle and a time that works for you. Business hours are 10:00 AM to 5:30 PM.') %></p>
  </header>

  <% if (typeof error !== 'undefined' && error) { %>
    <div class="form-alert form-alert-error"><%= error %></div>
  <% } %>

  <form action="/book" method="POST" class="professional-form">
    <!-- Car selection (optional) -->
    <label class="label" for="carId"><%= t('Car you would like to see') %></label>
    <select name="carId" id="carId">
      <option value="">— <%= t('Select Vehicle') %> —</option>
      <% if (Array.isArray(cars)) { %>
        <% cars.forEach(c => { %>
          <option value="<%= c._id %>" <%= (selectedCarId === String(c._id)) ? 'selected' : '' %>>
            <%= c.year %> <%= c.make %> <%= c.model %>
          </option>
        <% }) %>
      <% } %>
    </select>

    <input
      type="text"
      name="name"
      placeholder="<%= t('Your Name') %>"
      required
      value="<%= typeof name !== 'undefined' ? name : '' %>"
    />

    <input
      type="email"
      name="email"
      placeholder="<%= t('Your Email') %>"
      required
      value="<%= typeof email !== 'undefined' ? email : '' %>"
    />

    <input
      type="tel"
      name="phone"
      placeholder="<%= t('Phone Number') %>"
      required
      value="<%= typeof phone !== 'undefined' ? phone : '' %>"
    />

    <!-- Date + Time -->
    <div class="booking-date-row">
      <div>
        <label class="label" for="dateInput"><%= t('Date') %></label>
        <input
          id="dateInput"
          type="date"
          name="date"
          required
          min="<%= typeof minDate !== 'undefined' ? minDate : '' %>"
          value="<%= typeof date !== 'undefined' ? date : '' %>"
        />
      </div>
      <div>
        <label class="label" for="timeInput"><%= t('Time') %></label>
        <select id="timeInput" name="time" required>
          <option value=""><%= t('Select Time') %></option>

          <%
            const timeValues = [];
            for (let minutes = 10 * 60; minutes <= 17 * 60 + 30; minutes += 15) {
              timeValues.push(`${String(Math.floor(minutes / 60)).padStart(2, '0')}:${String(minutes % 60).padStart(2, '0')}`);
            }
            const times = timeValues.map(value => {
              const [hours, minutes] = value.split(':').map(Number);
              const display = new Intl.DateTimeFormat(locale, {
                hour: 'numeric',
                minute: '2-digit',
                hour12: lang === 'en'
              }).format(new Date(2000, 0, 1, hours, minutes));
              return [value, display];
            });
          %>

          <% times.forEach(t => { %>
            <option value="<%= t[0] %>" <%= time === t[0] ? 'selected' : '' %>>
              <%= t[1] %>
            </option>
          <% }) %>
        </select>
      </div>
    </div>

    <textarea
      name="message"
      placeholder="<%= t('Additional Info (optional)') %>"
    ><%= typeof message !== 'undefined' ? message : '' %></textarea>

    <button type="submit" class="btn btn-primary btn-block"><%= t('Book appointment') %></button>
  </form>

  <% if (success) { %>
    <div class="success-popup" id="successPopup">
      <%= t('Booking confirmed!') %>
    </div>
    <script>
      setTimeout(() => {
        const popup = document.getElementById('successPopup');
        if (popup) popup.style.display = 'none';
      }, 3000);
    </script>
  <% } %>

  <!-- Prevent Sundays -->
  <script>
    const dateInput = document.querySelector('input[name="date"]');
    if (dateInput) {
      dateInput.addEventListener('input', () => {
        const picked = new Date(dateInput.value);
        if (picked.getDay() === 0) {
          alert(<%- JSON.stringify(t('We are closed on Sundays. Please choose another day.')) %>);
          dateInput.value = '';
        }
      });
      dateInput.addEventListener('keydown', e => e.preventDefault());
    }
  </script>
</section>

<%- include('partials/footer') %>
