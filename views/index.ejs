<%- include('partials/header') %>

<%
  // Force the billboard to use your Porsche banner image at the top
  const heroBg = '/images/porsche-banner.jpeg';
%>

<section class="billboard home-hero" style="--billboard:url(<%= heroBg %>)">
  <div class="billboard-inner container">
    <div class="bb-copy">
      <span class="eyebrow"><%= t('Pre-owned vehicles in Montreal') %></span>
      <h1><%= t('Quality vehicles. Trusted service.') %></h1>
      <p class="bb-sub"><%= t('Browse our current inventory or book a private visit.') %></p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="/inventory"><%= t('Browse inventory') %></a>
        <a class="btn btn-secondary" href="/book"><%= t('Book a visit') %></a>
        <a class="hero-text-link" href="/trade-in"><%= t('Selling your car?') %> <span><%= t('Get started') %></span></a>
      </div>
    </div>
  </div>
</section>

<section class="warranty-band" aria-labelledby="warranty-title">
  <div class="container warranty-band-inner">
    <div class="warranty-mark" aria-hidden="true">
      <svg viewBox="0 0 24 24" role="img">
        <path d="M12 3 19 6v5c0 4.8-2.8 8.1-7 10-4.2-1.9-7-5.2-7-10V6l7-3Z" />
        <path d="m9 12 2 2 4-5" />
      </svg>
    </div>
    <div class="warranty-copy">
      <h2 id="warranty-title"><%= t('Extended warranty coverage available') %></h2>
      <p><%= t('Protect your purchase with National warranty options. Ask our team for details.') %></p>
    </div>
    <a class="warranty-link" href="/contact"><%= t('Ask about coverage') %></a>
  </div>
</section>

<section class="container section home-inventory-section">
  <div class="section-heading section-heading-row">
    <div>
      <span class="section-eyebrow"><%= t('Just arrived') %></span>
      <h2 class="section-title"><%= t('Latest vehicle') %></h2>
    </div>
    <a class="section-link" href="/inventory"><%= t('View all inventory') %></a>
  </div>

  <% if (typeof featuredCar !== 'undefined' && featuredCar) { %>
    <a href="/inventory/<%= featuredCar._id %>" class="spotlight">
      <div class="spotlight-media">
        <div class="spotlight-noimg"><%= t('No image') %></div>
        <% if (featuredCar.images && featuredCar.images.length) { %>
          <img src="<%= featuredCar.images[0] %>" alt="<%= featuredCar.make %> <%= featuredCar.model %>" onerror="this.style.display='none'" />
        <% } %>

        <span class="spotlight-badge"><%= t('New arrival') %></span>
        <span class="spotlight-chip"><%= featuredCar.year %></span>

        <% if (typeof featuredCar.price === 'number') { %>
          <span class="spotlight-price"><%= new Intl.NumberFormat(locale, { style: 'currency', currency: 'CAD', maximumFractionDigits: 0 }).format(featuredCar.price) %></span>
        <% } %>
      </div>

      <div class="spotlight-caption">
        <h3><%= featuredCar.make %> <%= featuredCar.model %></h3>
        <% if (typeof featuredCar.mileage === 'number') { %>
          <span class="meta"><%= new Intl.NumberFormat(locale).format(featuredCar.mileage) %> km</span>
        <% } %>
      </div>
    </a>
  <% } else { %>
    <p class="empty-state"><%= t('Add a car in Admin to showcase it here.') %></p>
  <% } %>
</section>

<%- include('partials/footer') %>
