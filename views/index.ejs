<%- include('partials/header') %>

<%
  // Force the billboard to use your Porsche banner image at the top
  const heroBg = '/images/porsche-banner.jpeg';
%>

<section class="billboard home-hero" style="--billboard:url(<%= heroBg %>)">
  <div class="billboard-inner container">
    <div class="bb-copy">
      <span class="eyebrow">Pre-owned vehicles in Montreal</span>
      <div class="hero-actions">
        <a class="btn btn-primary" href="/inventory">Browse inventory</a>
        <a class="btn btn-secondary" href="/book">Book a visit</a>
        <a class="hero-text-link" href="/trade-in">Selling your car? <span>Get started</span></a>
      </div>
    </div>
  </div>
</section>

<section class="container section">
  <div class="section-heading">
    <span class="section-eyebrow">Why MED AUTO</span>
    <h2 class="section-title">A simpler way to buy pre-owned.</h2>
  </div>
  <div class="features">
    <div class="feature">
      <span class="feature-number">01</span>
      <h3>Carefully selected</h3>
      <p>Each car is checked for mechanical and cosmetic quality.</p>
    </div>
    <div class="feature">
      <span class="feature-number">02</span>
      <h3>Clear from the start</h3>
      <p>No games. Clear pricing and straightforward deals.</p>
    </div>
    <div class="feature">
      <span class="feature-number">03</span>
      <h3>Personal service</h3>
      <p>Speak directly with our team and book a test drive in minutes.</p>
    </div>
  </div>
</section>

<section class="container section">
  <div class="section-heading section-heading-row">
    <div>
      <span class="section-eyebrow">Just arrived</span>
      <h2 class="section-title">Latest vehicle</h2>
    </div>
    <a class="section-link" href="/inventory">View all inventory</a>
  </div>

  <% if (typeof featuredCar !== 'undefined' && featuredCar) { %>
    <a href="/inventory/<%= featuredCar._id %>" class="spotlight">
      <div class="spotlight-media">
        <% if (featuredCar.images && featuredCar.images.length) { %>
          <img src="<%= featuredCar.images[0] %>" alt="<%= featuredCar.make %> <%= featuredCar.model %>" />
        <% } %>

        <span class="spotlight-badge">New arrival</span>
        <span class="spotlight-chip"><%= featuredCar.year %></span>

        <% if (typeof featuredCar.price === 'number') { %>
          <span class="spotlight-price">$<%= featuredCar.price.toLocaleString() %></span>
        <% } %>
      </div>

      <div class="spotlight-caption">
        <h3><%= featuredCar.make %> <%= featuredCar.model %></h3>
        <% if (typeof featuredCar.mileage === 'number') { %>
          <span class="meta"><%= featuredCar.mileage.toLocaleString() %> km</span>
        <% } %>
      </div>
    </a>
  <% } else { %>
    <p class="empty-state">Add a car in Admin to showcase it here.</p>
  <% } %>
</section>

<section class="cta-strip">
  <div class="container">
    <div>
      <span class="section-eyebrow">Visit us in Dorval</span>
      <h2>See something you like?</h2>
      <p>Book a private viewing or test drive with our team.</p>
    </div>
    <a href="/book" class="btn btn-primary">Book a visit</a>
  </div>
</section>

<%- include('partials/footer') %>
