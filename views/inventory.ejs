<%- include('partials/header') %>
<section class="container stack-l inventory-page">
  <header class="page-heading">
    <span class="section-eyebrow"><%= t('Available vehicles') %></span>
    <h1><%= t('Inventory') %></h1>
    <p><%= t('Browse our current selection of pre-owned vehicles.') %></p>
  </header>

  <form method="GET" action="/inventory" class="inventory-filters">
    <label><span><%= t('Make') %></span><select name="make">
      <option value="all" <%= selectedMake === 'all' ? 'selected' : '' %>><%= t('All Makes') %></option>
      <% makes.forEach(m => { %>
        <option value="<%= m %>" <%= selectedMake === m ? 'selected' : '' %>><%= m %></option>
      <% }) %>
    </select></label>

    <label><span><%= t('Year') %></span><select name="year">
      <option value="all" <%= selectedYear === 'all' ? 'selected' : '' %>><%= t('All Years') %></option>
      <% years.sort((a,b)=>b-a).forEach(y => { %>
        <option value="<%= y %>" <%= selectedYear == y ? 'selected' : '' %>><%= y %></option>
      <% }) %>
    </select></label>

    <label><span><%= t('Sort') %></span><select name="sort">
      <option value=""><%= t('Sort By') %></option>
      <option value="price-asc"  <%= selectedSort === 'price-asc'  ? 'selected' : '' %>><%= t('Price: Low to High') %></option>
      <option value="price-desc" <%= selectedSort === 'price-desc' ? 'selected' : '' %>><%= t('Price: High to Low') %></option>
      <option value="year-asc"   <%= selectedSort === 'year-asc'   ? 'selected' : '' %>><%= t('Year: Oldest') %></option>
      <option value="year-desc"  <%= selectedSort === 'year-desc'  ? 'selected' : '' %>><%= t('Year: Newest') %></option>
    </select></label>

    <input type="hidden" name="showSold" value="<%= showSold %>" />

    <button type="submit" class="btn btn-primary"><%= t('Apply filters') %></button>

<a href="/inventory" class="btn btn-muted inventory-reset">
  <%= t('Reset') %>
</a>

<a
  href="/inventory?make=<%= selectedMake %>&year=<%= selectedYear %>&sort=<%= selectedSort %>&showSold=<%= showSold === 'true' ? 'false' : 'true' %>"
  class="btn <%= showSold === 'true' ? 'btn-primary' : 'btn-muted' %>"
>
      <%= showSold === 'true' ? t('Hide Sold Cars') : t('Show Sold Cars') %>
    </a>
  </form>

  <% if (cars.length > 0) { %>
    <div class="vehicle-grid">
      <% cars.forEach(car => { %>
        <a href="/inventory/<%= car._id %>" class="vehicle-card">
          <div class="vehicle-media">
            <% if (car.images && car.images.length > 0) { %>
              <img
                src="<%= car.images[0] %>"
                alt="<%= car.make %> <%= car.model %>"
                class="<%= car.sold ? 'is-sold-image' : '' %>"
              />
            <% } else { %>
              <div class="vehicle-noimg"><%= t('No image') %></div>
            <% } %>

            <% if (car.sold) { %>
              <div class="sold-badge"><%= t('SOLD') %></div>
            <% } %>
          </div>

          <div class="vehicle-caption">
            <h3><%= car.year %> <%= car.make %> <%= car.model %></h3>

            <% if (typeof car.mileage === 'number') { %>
              <p class="meta"><%= new Intl.NumberFormat(locale).format(car.mileage) %> km</p>
            <% } %>

            <% if (!car.sold && car.price && car.price > 0) { %>
              <p class="price"><%= new Intl.NumberFormat(locale, { style: 'currency', currency: 'CAD', maximumFractionDigits: 0 }).format(car.price) %></p>
            <% } %>
            <span class="vehicle-card-link"><%= t('View details') %></span>
          </div>
        </a>
      <% }) %>
    </div>

    <div class="pager">
      <% if (currentPage > 1) { %>
        <a href="?page=<%= currentPage - 1 %>&make=<%= selectedMake %>&year=<%= selectedYear %>&sort=<%= selectedSort %>&showSold=<%= showSold %>" class="pagination-btn"><%= t('Previous') %></a>
      <% } %>

      <% for (let i = 1; i <= totalPages; i++) { %>
        <a href="?page=<%= i %>&make=<%= selectedMake %>&year=<%= selectedYear %>&sort=<%= selectedSort %>&showSold=<%= showSold %>" class="pagination-btn <%= i === currentPage ? 'active' : '' %>"><%= i %></a>
      <% } %>

      <% if (currentPage < totalPages) { %>
        <a href="?page=<%= currentPage + 1 %>&make=<%= selectedMake %>&year=<%= selectedYear %>&sort=<%= selectedSort %>&showSold=<%= showSold %>" class="pagination-btn"><%= t('Next') %></a>
      <% } %>
    </div>
  <% } else { %>
    <p><%= t('No cars match your filter.') %></p>
  <% } %>
</section>
<%- include('partials/footer') %>
