<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= t('MED AUTO | Pre-owned vehicles in Dorval') %></title>

  <!-- Google Font -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Manrope:wght@600;700&display=swap" rel="stylesheet">

  <!-- Favicon / App Icons -->
  <link rel="icon" type="image/png" sizes="32x32" href="/images/favicon-32.png?v=4">
  <link rel="apple-touch-icon" sizes="180x180" href="/images/favicon-180.png?v=4">
  <link rel="icon" type="image/png" sizes="192x192" href="/images/med-auto-logo-192.png?v=4">
  <link rel="icon" type="image/png" sizes="512x512" href="/images/favicon-512.png?v=4">
  <link rel="shortcut icon" href="/images/favicon-32.png?v=4">
  <meta property="og:image" content="https://medauto.ca/images/med-auto-logo-512.png">
  <meta name="twitter:image" content="https://medauto.ca/images/med-auto-logo-512.png">
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "AutoDealer",
      "name": "MED AUTO",
      "url": "https://medauto.ca/",
      "logo": "https://medauto.ca/images/med-auto-logo-512.png",
      "image": "https://medauto.ca/images/med-auto-logo-512.png",
      "telephone": "+15144634503",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "2046 Avenue Chartier",
        "addressLocality": "Dorval",
        "addressRegion": "QC",
        "postalCode": "H9P 1H2",
        "addressCountry": "CA"
      },
      "sameAs": [
        "https://instagram.com/medauto_mtl"
      ]
    }
  </script>

  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <!-- Top contact bar -->
  <div class="topbar">
    <div class="container topbar-inner">
      <div class="topbar-right">
        <a class="topbar-link" href="tel:+15144634503">
          <strong class="contact-full">Tom: (514) 463-4503</strong>
          <strong class="contact-short"><%= t('Call Tom') %></strong>
        </a>
        <span class="divider">•</span>
        <a class="topbar-link" href="tel:+15147751722">
          <strong class="contact-full">Dimitri: (514) 775-1722</strong>
          <strong class="contact-short"><%= t('Call Dimitri') %></strong>
        </a>
        <span class="divider">•</span>
        <a class="topbar-link hide-on-phone" href="https://instagram.com/medauto_mtl" target="_blank" rel="noopener">@MEDAUTO_MTL</a>
        <span class="divider">•</span>
        <a class="topbar-link" href="https://maps.google.com/?q=2046+Avenue+Chartier,+Dorval,+QC+H9P+1H2" target="_blank" rel="noopener">
          <span class="addr-long">2046 Avenue Chartier, Dorval, QC H9P 1H2</span>
          <span class="addr-short"><%= t('Directions') %></span>
        </a>
      </div>
    </div>
  </div>

  <!-- Main nav -->
  <header class="site-header">
    <nav class="nav container">
      <a href="/" class="wordmark nav-wordmark" aria-label="<%= t('MED AUTO Home') %>">
        <img class="wm-logo" src="/images/med-auto-logo-192.png?v=4" alt="" width="42" height="42" />
        <span class="wm-text">
          <span class="wm-title">MED AUTO</span>
          <span class="wm-sub"><%= t('SALES - FINANCING - TRADE-INS') %></span>
        </span>
      </a>

      <button class="nav-toggle" type="button" aria-controls="primary-nav" aria-expanded="false" aria-label="<%= t('Open navigation menu') %>" data-open-label="<%= t('Open navigation menu') %>" data-close-label="<%= t('Close navigation menu') %>">
        <span class="nav-toggle-icon" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </span>
        <span class="nav-toggle-label"><%= t('Menu') %></span>
      </button>

      <ul id="primary-nav" class="nav-links">
        <li><a href="/"><%= t('Home') %></a></li>
        <li><a href="/inventory"><%= t('Inventory') %></a></li>
        <li><a href="/trade-in"><%= t('Sell or Trade') %></a></li>
        <li><a href="/book"><%= t('Booking') %></a></li>
        <li><a href="/contact"><%= t('Contact') %></a></li>

        <% if (typeof session !== 'undefined' && session.admin) { %>
          <li><a href="/admin/dashboard"><%= t('Admin') %></a></li>
          <li><a href="/admin/command-center">Command Center</a></li>
        <% } %>
      </ul>

      <% if (showLanguageSwitch) { %>
        <div class="language-switch" aria-label="Language / Langue">
          <a href="<%= languageUrls.en %>" lang="en" class="<%= lang === 'en' ? 'active' : '' %>" <%= lang === 'en' ? 'aria-current="true"' : '' %>>EN</a>
          <span aria-hidden="true">/</span>
          <a href="<%= languageUrls.fr %>" lang="fr" class="<%= lang === 'fr' ? 'active' : '' %>" <%= lang === 'fr' ? 'aria-current="true"' : '' %>>FR</a>
        </div>
      <% } %>
    </nav>
  </header>

  <main class="page">
