<%- include('partials/header') %>

<section class="form-card trade-page">
  <header class="form-page-heading">
    <span class="section-eyebrow"><%= t('Vehicle acquisition') %></span>
    <h1 class="form-title"><%= t('Sell or trade your car') %></h1>
    <p><%= t('Share a few details and our team will get back to you with a straightforward evaluation.') %></p>
  </header>

  <% if (typeof error !== 'undefined' && error) { %>
    <div class="form-alert form-alert-error">
      <%= error %>
    </div>
  <% } %>

  <% if (typeof success !== 'undefined' && success) { %>
    <div class="success-popup" id="successPopup">
      <%= t('Request sent successfully! We will get back to you soon.') %>
    </div>
  <% } %>

  <form id="tradeInForm" action="/trade-in" method="POST" enctype="multipart/form-data" class="form">
    <h3 class="form-section-heading"><%= t('Your information') %></h3>

    <input
      type="text"
      name="name"
      placeholder="<%= t('Your Name') %>"
      required
      value="<%= typeof formData !== 'undefined' ? formData.name || '' : '' %>"
    />

    <input
      type="email"
      name="email"
      placeholder="<%= t('Your Email') %>"
      value="<%= typeof formData !== 'undefined' ? formData.email || '' : '' %>"
    />

    <input
      type="tel"
      name="phone"
      placeholder="<%= t('Phone Number') %>"
      required
      value="<%= typeof formData !== 'undefined' ? formData.phone || '' : '' %>"
    />

    <h3 class="form-section-heading form-section-heading-spaced"><%= t('Vehicle information') %></h3>

    <div class="form-row">
      <input
  type="text"
  inputmode="numeric"
  pattern="[0-9]*"
  maxlength="4"
  name="year"
        placeholder="<%= t('Year') %>"
        required
        value="<%= typeof formData !== 'undefined' ? formData.year || '' : '' %>"
      />

      <input
        type="text"
        name="make"
        placeholder="<%= t('Make') %>"
        required
        value="<%= typeof formData !== 'undefined' ? formData.make || '' : '' %>"
      />
    </div>

    <input
      type="text"
      name="model"
      placeholder="<%= t('Model') %>"
      required
      value="<%= typeof formData !== 'undefined' ? formData.model || '' : '' %>"
    />

    <input
      type="number"
      name="mileage"
      placeholder="<%= t('Mileage (km)') %>"
      required
      value="<%= typeof formData !== 'undefined' ? formData.mileage || '' : '' %>"
    />

    <input
      type="text"
      name="vin"
      placeholder="<%= t('VIN (optional)') %>"
      value="<%= typeof formData !== 'undefined' ? formData.vin || '' : '' %>"
    />

    <select name="condition">
      <option value=""><%= t('Vehicle Condition') %></option>

      <option
        value="Excellent"
        <%= typeof formData !== 'undefined' && formData.condition === 'Excellent' ? 'selected' : '' %>
      >
        <%= t('Excellent') %>
      </option>

      <option
        value="Good"
        <%= typeof formData !== 'undefined' && formData.condition === 'Good' ? 'selected' : '' %>
      >
        <%= t('Good') %>
      </option>

      <option
        value="Fair"
        <%= typeof formData !== 'undefined' && formData.condition === 'Fair' ? 'selected' : '' %>
      >
        <%= t('Fair') %>
      </option>

      <option
        value="Needs Work"
        <%= typeof formData !== 'undefined' && formData.condition === 'Needs Work' ? 'selected' : '' %>
      >
        <%= t('Needs Work') %>
      </option>
    </select>

    <input
      type="number"
      name="askingPrice"
      placeholder="<%= t('Asking Price (optional)') %>"
      value="<%= typeof formData !== 'undefined' ? formData.askingPrice || '' : '' %>"
    />

    <div>
      <label class="label"><%= t('Upload Photos (optional)') %></label>

      <label for="tradeImages" class="custom-upload-btn">
  <%= t('Choose Photos') %>
</label>

<input
  id="tradeImages"
  type="file"
  name="images"
  accept="image/*"
  multiple
  hidden
/>

      <small class="form-helper">
        <%= t('Upload up to 10 photos. You can drag photos to reorder them.') %>
      </small>

      <div id="tradePreviewGrid" class="trade-preview-grid"></div>
    </div>

    <textarea
      name="message"
      placeholder="<%= t('Anything else we should know? Accidents, repairs, warning lights, etc.') %>"
    ><%= typeof formData !== 'undefined' ? formData.message || '' : '' %></textarea>

    <button
      id="tradeSubmitBtn"
      type="submit"
      class="btn btn-primary btn-block"
    >
      <%= t('Submit Vehicle') %>
    </button>
  </form>

  <script>
    const form = document.getElementById('tradeInForm');
    const fileInput = document.getElementById('tradeImages');
    const submitBtn = document.getElementById('tradeSubmitBtn');
    const previewGrid = document.getElementById('tradePreviewGrid');

    let selectedFiles = [];
    let draggedIndex = null;

    const uploadWarning = document.createElement('div');

    uploadWarning.className = 'trade-upload-warning';
    uploadWarning.style.display = 'none';

    fileInput.parentNode.appendChild(uploadWarning);

    function syncFileInput() {

      const dt = new DataTransfer();

      selectedFiles.forEach(file => {
        dt.items.add(file);
      });

      fileInput.files = dt.files;
    }

    function showUploadWarning(message) {

      uploadWarning.style.display = 'block';
      uploadWarning.textContent = message;
    }

    function hideUploadWarning() {

      uploadWarning.style.display = 'none';
      uploadWarning.textContent = '';
    }

    function renderTradePreviews() {

      previewGrid.innerHTML = '';

      selectedFiles.forEach((file, index) => {

        const url = URL.createObjectURL(file);

        const card = document.createElement('div');

        card.className = 'trade-preview-card';
        card.draggable = true;
        card.dataset.index = index;

        card.innerHTML = `
          <img src="${url}" alt="Preview ${index + 1}">

          <button
            type="button"
            class="trade-remove-btn"
            data-index="${index}"
          >
            ×
          </button>

          <div class="trade-preview-number">
            ${index + 1}
          </div>
        `;

        card.addEventListener('dragstart', () => {

          draggedIndex = index;

          card.classList.add('dragging');
        });

        card.addEventListener('dragend', () => {

          draggedIndex = null;

          card.classList.remove('dragging');

          document.querySelectorAll('.trade-preview-card')
            .forEach(c => c.classList.remove('drag-over'));
        });

        card.addEventListener('dragover', (e) => {

          e.preventDefault();

          document.querySelectorAll('.trade-preview-card')
            .forEach(c => c.classList.remove('drag-over'));

          card.classList.add('drag-over');
        });

        card.addEventListener('dragleave', () => {

          card.classList.remove('drag-over');
        });

        card.addEventListener('drop', (e) => {

          e.preventDefault();

          document.querySelectorAll('.trade-preview-card')
            .forEach(c => c.classList.remove('drag-over'));

          const dropIndex = Number(card.dataset.index);

          if (
            draggedIndex === null ||
            draggedIndex === dropIndex
          ) return;

          const movedFile =
            selectedFiles.splice(draggedIndex, 1)[0];

          selectedFiles.splice(dropIndex, 0, movedFile);

          syncFileInput();
          renderTradePreviews();
        });

        card.querySelector('.trade-remove-btn')
          .addEventListener('click', () => {

            selectedFiles.splice(index, 1);

            syncFileInput();
            renderTradePreviews();

            hideUploadWarning();
          });

        previewGrid.appendChild(card);
      });
    }

    fileInput.addEventListener('change', () => {

      selectedFiles = Array.from(fileInput.files || []);

      if (selectedFiles.length > 10) {

        selectedFiles = [];

        fileInput.value = '';

        previewGrid.innerHTML = '';

        showUploadWarning(
          <%- JSON.stringify(t('You can upload a maximum of 10 photos. Please remove a few images and try again.')) %>
        );

        return;
      }

      hideUploadWarning();

      renderTradePreviews();
    });

    function updateFilledFields() {

      document.querySelectorAll(
        '.trade-page input, .trade-page textarea, .trade-page select'
      ).forEach(el => {

        if (el.type === 'file') return;

        if (el.value && el.value.trim() !== '') {

          el.classList.add('has-value');

        } else {

          el.classList.remove('has-value');

        }
      });
    }

    document.querySelectorAll(
      '.trade-page input, .trade-page textarea, .trade-page select'
    ).forEach(el => {

      el.addEventListener('input', updateFilledFields);
      el.addEventListener('change', updateFilledFields);
    });

    updateFilledFields();

    function fileToImage(file) {

      return new Promise((resolve, reject) => {

        const url = URL.createObjectURL(file);

        const img = new Image();

        img.onload = () => {

          URL.revokeObjectURL(url);

          resolve(img);
        };

        img.onerror = reject;

        img.src = url;
      });
    }

    async function compressImage(
      file,
      maxWidth = 1000,
      quality = 0.58
    ) {

      const img = await fileToImage(file);

      const canvas = document.createElement('canvas');

      const scale = Math.min(
        1,
        maxWidth / img.width
      );

      canvas.width = Math.round(img.width * scale);
      canvas.height = Math.round(img.height * scale);

      const ctx = canvas.getContext('2d');

      ctx.drawImage(
        img,
        0,
        0,
        canvas.width,
        canvas.height
      );

      const blob = await new Promise(resolve => {

        canvas.toBlob(
          resolve,
          'image/webp',
          quality
        );
      });

      return new File(
        [blob],
        file.name.replace(/\.[^.]+$/, '') + '.webp',
        {
          type: 'image/webp',
          lastModified: Date.now()
        }
      );
    }

    form.addEventListener('submit', async (e) => {

      e.preventDefault();

      if (selectedFiles.length > 10) {

        showUploadWarning(
          <%- JSON.stringify(t('You can upload a maximum of 10 photos. Please remove a few images and try again.')) %>
        );

        return;
      }

      submitBtn.disabled = true;

      submitBtn.textContent = <%- JSON.stringify(t('Submitting...')) %>;

      try {

        const fd = new FormData(form);

        fd.delete('images');

        for (const file of selectedFiles) {

          const compressed =
            await compressImage(file);

          fd.append(
            'images',
            compressed,
            compressed.name
          );
        }

        const response = await fetch(
          form.action,
          {
            method: 'POST',
            body: fd
          }
        );

        const html = await response.text();

        document.open();
        document.write(html);
        document.close();

      } catch (err) {

        console.error(err);

        alert(
          <%- JSON.stringify(t('Something went wrong submitting the form. Please try again.')) %>
        );

        submitBtn.disabled = false;

        submitBtn.textContent = <%- JSON.stringify(t('Submit Vehicle')) %>;
      }
    });
  </script>

  <% if (typeof success !== 'undefined' && success) { %>
    <script>
      setTimeout(() => {

        const popup =
          document.getElementById('successPopup');

        if (popup) popup.style.display = 'none';

      }, 3500);
    </script>
  <% } %>
</section>

<%- include('partials/footer') %>
